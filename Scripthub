local function createRosterWindow(titleName, onClickCallback)
    local Window = Instance.new("Frame")
    Window.Size = UDim2.new(0, 350, 0, 400)
    Window.Position = UDim2.new(0.5, -175, 0.5, -200)
    Window.BackgroundColor3 = themes[state.currentTheme].background
    Window.BackgroundTransparency = state.globalTransparency
    Window.BorderSizePixel = 0
    Window.Visible = false
    Window.Active = true
    Window.Draggable = true
    Window.Parent = ScreenGui
    registeredUIElements[Window] = "MainPanel"

    local Corner = Instance.new("UICorner") Corner.CornerRadius = UDim.new(0, 8) Corner.Parent = Window
    local Stroke = Instance.new("UIStroke") Stroke.Color = themes[state.currentTheme].stroke Stroke.Thickness = 1 Stroke.Transparency = state.globalTransparency Stroke.Parent = Window
    registeredUIElements[Stroke] = "Stroke"

    local Title = Instance.new("TextLabel")
    Title.Size = UDim2.new(1, -110, 0, 35) Title.Position = UDim2.new(0, 15, 0, 0)
    Title.BackgroundTransparency = 1 Title.Text = titleName Title.TextColor3 = Color3.fromRGB(255, 255, 255)
    Title.TextSize = 14 Title.Font = fontMapping[state.currentFont] Title.TextXAlignment = Enum.TextXAlignment.Left Title.Parent = Window
    registeredUIElements[Title] = "Text"

    local Close = Instance.new("TextButton")
    Close.Size = UDim2.new(0, 35, 0, 35) Close.Position = UDim2.new(1, -35, 0, 0) Close.BackgroundTransparency = 1
    Close.Text = "✕" Close.TextColor3 = Color3.fromRGB(180, 50, 50) Close.TextSize = 16 Close.Font = Enum.Font.SourceSansBold Close.Parent = Window
    Close.MouseButton1Click:Connect(function() Window.Visible = false end)

    local Refresh = Instance.new("TextButton")
    Refresh.Size = UDim2.new(0, 35, 0, 35) Refresh.Position = UDim2.new(1, -70, 0, 0) Refresh.BackgroundTransparency = 1
    Refresh.Text = "⟳" Refresh.TextColor3 = Color3.fromRGB(50, 180, 50) Refresh.TextSize = 18 Refresh.Font = Enum.Font.SourceSansBold Refresh.Parent = Window

    local Scroll = Instance.new("ScrollingFrame")
    Scroll.Size = UDim2.new(1, -20, 1, -50) Scroll.Position = UDim2.new(0, 10, 0, 40) Scroll.BackgroundTransparency = 1
    Scroll.BorderSizePixel = 0 Scroll.ScrollBarThickness = 4 Scroll.ScrollBarImageColor3 = Color3.fromRGB(100, 100, 100) Scroll.Parent = Window

    local List = Instance.new("UIListLayout") List.Padding = UDim.new(0, 5) List.SortOrder = Enum.SortOrder.LayoutOrder List.Parent = Scroll

    local function populateRoster()
        for _, child in ipairs(Scroll:GetChildren()) do if child:IsA("TextButton") then child:Destroy() end end
        for _, player in ipairs(Players:GetPlayers()) do
            if player ~= LocalPlayer then
                local row = Instance.new("TextButton")
                row.Size = UDim2.new(1, -10, 0, 30)
                row.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
                row.Text = "   " .. player.DisplayName .. " (@" .. player.Name .. ")"
                row.TextColor3 = Color3.fromRGB(220, 220, 220)
                row.TextSize = 14 row.Font = fontMapping[state.currentFont] row.TextXAlignment = Enum.TextXAlignment.Left
                row.Parent = Scroll
                Instance.new("UICorner", row).CornerRadius = UDim.new(0, 4)
                registeredUIElements[row] = "Text"
                
                onClickCallback(player, row)
            end
        end
        Scroll.CanvasSize = UDim2.new(0, 0, 0, List.AbsoluteContentSize.Y + 20)
    end

    local isMin = false
    local originalHeight = Window.Size.Y.Offset
    local Min = Instance.new("TextButton")
    Min.Size = UDim2.new(0, 35, 0, 35) Min.Position = UDim2.new(1, -105, 0, 0) Min.BackgroundTransparency = 1
    Min.Text = "—" Min.TextColor3 = Color3.fromRGB(200, 200, 200) Min.TextSize = 14 Min.Font = Enum.Font.SourceSansBold Min.Parent = Window
    Min.MouseButton1Click:Connect(function()
        isMin = not isMin
        if isMin then
            Scroll.Visible = false
            Window:TweenSize(UDim2.new(0, 350, 0, 35), "Out", "Quad", 0.15, true)
        else
            Window:TweenSize(UDim2.new(0, 350, 0, originalHeight), "Out", "Quad", 0.15, true, function() Scroll.Visible = true end)
        end
    end)

    Refresh.MouseButton1Click:Connect(populateRoster)
    return Window, populateRoster
end

-- Helper matching routine to check both user accounts and customized nickname display profiles
local function findPlayerByNameOrDisplay(searchStr)
    local target = string.lower(searchStr)
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            if string.sub(string.lower(player.Name), 1, string.len(target)) == target or 
               string.sub(string.lower(player.DisplayName), 1, string.len(target)) == target then
                return player
            end
        end
    end
    return nil
end

