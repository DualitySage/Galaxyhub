local function refreshWhitelistRoster()
    for _, child in ipairs(WlScroll:GetChildren()) do
        if child:IsA("TextButton") then child:Destroy() end
    end
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            local row = Instance.new("TextButton")
            row.Size = UDim2.new(1, -10, 0, 30)
            row.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
            row.BackgroundTransparency = state.whitelistedUsers[player.Name] and 0 or 1
            row.Text = "   " .. player.Name
            row.TextColor3 = state.whitelistedUsers[player.Name] and Color3.fromRGB(100, 255, 100) or Color3.fromRGB(220, 220, 220)
            row.TextSize = 14
            row.Font = Enum.Font.SourceSans
            row.TextXAlignment = Enum.TextXAlignment.Left
            row.Parent = WlScroll
            
            local rowCorner = Instance.new("UICorner")
            rowCorner.CornerRadius = UDim.new(0, 4)
            rowCorner.Parent = row
            
            row.MouseButton1Click:Connect(function()
                if state.whitelistedUsers[player.Name] then
                    state.whitelistedUsers[player.Name] = nil
                    row.BackgroundTransparency = 1
                    row.TextColor3 = Color3.fromRGB(220, 220, 220)
                else
                    state.whitelistedUsers[player.Name] = true
                    row.BackgroundTransparency = 0
                    row.BackgroundColor3 = Color3.fromRGB(50, 150, 50)
                    row.TextColor3 = Color3.fromRGB(255, 255, 255)
                end
            end)
        end
    end
    WlScroll.CanvasSize = UDim2.new(0, 0, 0, WlListLayout.AbsoluteContentSize.Y + 20)
end

