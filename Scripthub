-- Core Physics Pipeline (Loops, Flight Frame Stability, Collisions, Multi-Jump)
RunService.Stepped:Connect(function()
    local char = LocalPlayer.Character
    if not char then return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    local root = char:FindFirstChild("HumanoidRootPart")
    
    -- Dynamic Parameter Variable Locks
    if hum then
        if state.loopSpeed then hum.WalkSpeed = state.loopSpeed end
        if state.loopJump then 
            hum.JumpPower = state.loopJump 
            hum.UseJumpPower = true 
        end
    end
    
    -- Camera-Relative Frozen Inertia Static Flight System
    if state.isFlying and root and hum then
        hum.PlatformStand = true
        local cam = workspace.CurrentCamera
        local moveDirection = Vector3.new()
        
        if UserInputService:IsKeyDown(Enum.KeyCode.W) then moveDirection += cam.CFrame.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) then moveDirection -= cam.CFrame.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) then moveDirection -= cam.CFrame.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) then moveDirection += cam.CFrame.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.Space) then moveDirection += Vector3.new(0, 1, 0) end
        if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then moveDirection -= Vector3.new(0, 1, 0) end
        
        if moveDirection.Magnitude > 0 then
            state.flyBV.Velocity = moveDirection.Unit * state.flySpeed
        else
            state.flyBV.Velocity = Vector3.new(0, 0, 0) -- Instant zero-friction stall
        end
        state.flyBG.CFrame = cam.CFrame
    end
    
    -- Noclip Workspace Collision Layer Bypass
    if state.isNoclipping then
        for _, part in ipairs(char:GetDescendants()) do
            if part:IsA("BasePart") then
                part.CanCollide = false
            end
        end
    end
end)

-- Helper Functions
local function stopFlying()
    state.isFlying = false
    if state.flyBV then state.flyBV:Destroy() state.flyBV = nil end
    if state.flyBG then state.flyBG:Destroy() state.flyBG = nil end
    local char = LocalPlayer.Character
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    if hum then hum.PlatformStand = false end
end

local function stopClickTP()
    state.isClickTPing = false
    if state.clickConnection then
        state.clickConnection:Disconnect()
        state.clickConnection = nil
    end
end

local function stopSpinning()
    state.isSpinning = false
    if state.spinVelocity then state.spinVelocity:Destroy() state.spinVelocity = nil end
    if state.spinGyro then state.spinGyro:Destroy() state.spinGyro = nil end
    if state.flingPart then state.flingPart:Destroy() state.flingPart = nil end
    local att = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") and LocalPlayer.Character.HumanoidRootPart:FindFirstChild("SpinAttachment")
    if att then att:Destroy() end
end

