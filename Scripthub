-- Core Physics Pipeline (Handles Flying Frame Stability, Collisions, Loops & Status Updates)
RunService.Stepped:Connect(function()
    local char = LocalPlayer.Character
    if not char then return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    local root = char:FindFirstChild("HumanoidRootPart")
    
    -- Dynamic Loop Locks
    if hum then
        if state.loopSpeed then hum.WalkSpeed = state.loopSpeed end
        if state.loopJump then 
            hum.JumpPower = state.loopJump 
            hum.UseJumpPower = true 
        end
    end
    
    -- Camera-Relative Stable Static Flight System
    if state.isFlying and root and hum then
        hum.PlatformStand = true
        local cam = workspace.CurrentCamera
        local moveDirection = Vector3.new()
        
        -- Map out input states natively relative to current perspective viewports
        if UserInputService:IsKeyDown(Enum.KeyCode.W) then moveDirection = moveDirection + cam.CFrame.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) then moveDirection = moveDirection - cam.CFrame.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) then moveDirection = moveDirection - cam.CFrame.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) then moveDirection = moveDirection + cam.CFrame.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.Space) then moveDirection = moveDirection + Vector3.new(0, 1, 0) end
        if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then moveDirection = moveDirection - Vector3.new(0, 1, 0) end
        
        -- FIX: Safely handles physics translation logic directly for BodyVelocity objects
        if moveDirection.Magnitude > 0 then
            if state.flyBV and state.flyBV.Parent then
                state.flyBV.Velocity = moveDirection.Unit * state.flySpeed
            end
        else
            if state.flyBV and state.flyBV.Parent then
                state.flyBV.Velocity = Vector3.new(0, 0, 0)
            end
        end
        
        -- FIX: Safely handles stability lock updates directly for BodyGyro objects
        if state.flyBG and state.flyBG.Parent then
            state.flyBG.CFrame = cam.CFrame
        end
    end
    
    -- Full-Frame Noclip Workspace Collision Layer Bypass
    if state.isNoclipping then
        for _, part in ipairs(char:GetDescendants()) do
            if part:IsA("BasePart") then
                part.CanCollide = false
            end
        end
    end
end)

-- Theme & Transparency Vector Synchronization Engine
local function syncUIStyling()
    local activeTheme = themes[state.currentTheme]
    local selectedFont = fontMapping[state.currentFont]
    
    for element, uiType in pairs(registeredUIElements) do
        if element and element.Parent then
            if uiType == "MainPanel" then
                element.BackgroundColor3 = activeTheme.background
                element.BackgroundTransparency = state.globalTransparency
            elseif uiType == "InnerPanel" then
                element.BackgroundColor3 = activeTheme.innerBg
                element.BackgroundTransparency = state.globalTransparency
            elseif uiType == "Stroke" then
                element.Color = activeTheme.stroke
                element.Transparency = state.globalTransparency
            elseif uiType == "Text" then
                element.Font = selectedFont
                element.TextTransparency = 0 -- Safeguard: text elements stay fully visible
            end
        else
            registeredUIElements[element] = nil
        end
    end
end

