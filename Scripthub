-- Live Predictive Autofill Target Storage
local currentAutofillTarget = ""
-- Live Predictive Auto-Suggestion Processor
TextBox:GetPropertyChangedSignal("Text"):Connect(function()
    local text = TextBox.Text
    local segments = string.split(text, " ")
    local searchStr = segments[1]:lower()
    if searchStr ~= "" then
        local foundMatch = false
        for _, cmdData in ipairs(commandDatabase) do
            local matchTarget = nil
            if string.sub(cmdData.name, 1, string.len(searchStr)) == searchStr then
                matchTarget = cmdData.name
            else
                for _, alias in ipairs(cmdData.aliases) do
                    if string.sub(alias, 1, string.len(searchStr)) == searchStr then
                        matchTarget = alias
                        break
                    end
                end
            end
            if matchTarget then
                local remainingArgs = ""
                if #segments > 1 then
                    remainingArgs = " " .. table.concat(segments, " ", 2)
                end
                SuggestionLabel.Text = searchStr .. string.sub(matchTarget, string.len(searchStr) + 1) .. remainingArgs
                currentAutofillTarget = matchTarget .. remainingArgs
                foundMatch = true
                break
            end
        end
        if not foundMatch then
            SuggestionLabel.Text = ""
            currentAutofillTarget = ""
        end
    else
        SuggestionLabel.Text = ""
        currentAutofillTarget = ""
    end
end)

-- Tab Completion Capturer
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if input.KeyCode == Enum.KeyCode.Tab and TextBox:HasFocus() then
        if currentAutofillTarget ~= "" then
            TextBox.Text = currentAutofillTarget
            TextBox.CursorPosition = string.len(TextBox.Text) + 1
            SuggestionLabel.Text = ""
        end
    end
end)

-- 8. Core Command Interpreter Engine
TextBox.FocusLost:Connect(function(enterPressed)
    if enterPressed then
        local rawText = TextBox.Text
        local segments = string.split(rawText, " ")
        local baseCommandClean = segments[1]:lower()
        local numericArg = tonumber(segments[2])
        for _, cmdData in ipairs(commandDatabase) do
            local isMatch = (baseCommandClean == cmdData.name)
            if not isMatch then
                for _, alias in ipairs(cmdData.aliases) do
                    if baseCommandClean == alias then
                        isMatch = true
                        break
                    end
                end
            end
            if isMatch then
                local char = LocalPlayer.Character
                local hum = char and char:FindFirstChildOfClass("Humanoid")
                local root = char and char:FindFirstChild("HumanoidRootPart")
                if cmdData.name == "commands" then
                    HelpFrame.Visible = true
                elseif cmdData.name == "speed" and numericArg then
                    state.loopSpeed = nil
                    if hum then hum.WalkSpeed = numericArg end
                elseif cmdData.name == "jumppower" and numericArg then
                    state.loopJump = nil
                    if hum then
                        hum.JumpPower = numericArg
                        hum.UseJumpPower = true
                    end
                elseif cmdData.name == "loopws" and numericArg then
                    state.loopSpeed = numericArg
                elseif cmdData.name == "loopjp" and numericArg then
                    state.loopJump = numericArg
                elseif cmdData.name == "unloopws" then
                    state.loopSpeed = nil
                    if hum then hum.WalkSpeed = 16 end
                elseif cmdData.name == "unloopjp" then
                    state.loopJump = nil
                    if hum then hum.JumpPower = 50 end
                elseif cmdData.name == "fly" then
                    if not state.isFlying and root then
                        state.isFlying = true
                        state.flyBV = Instance.new("BodyVelocity")
                        state.flyBV.MaxForce = Vector3.new(1e5, 1e5, 1e5)
                        state.flyBV.Velocity = Vector3.new(0, 0, 0)
                        state.flyBV.Parent = root
                        state.flyBG = Instance.new("BodyGyro")
                        state.flyBG.MaxTorque = Vector3.new(1e5, 1e5, 1e5)
                        state.flyBG.CFrame = root.CFrame
                        state.flyBG.Parent = root
                    end
                elseif cmdData.name == "unfly" then
                    stopFlying()
                elseif cmdData.name == "flyspeed" and numericArg then
                    state.flySpeed = numericArg
                elseif cmdData.name == "clicktp" then
                    stopClickTP()
                    state.isClickTPing = true
                    local mouse = LocalPlayer:GetMouse()
                    state.clickConnection = mouse.Button1Down:Connect(function()
                        local currentRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                        if currentRoot and mouse.Hit then
                            currentRoot.CFrame = CFrame.new(mouse.Hit.Position + Vector3.new(0, 3, 0))
                        end
                    end)
                elseif cmdData.name == "unclicktp" then
                    stopClickTP()
                elseif cmdData.name == "noclip" then
                    state.isNoclipping = true
                elseif cmdData.name == "clip" then
                    state.isNoclipping = false
                elseif cmdData.name == "infinitejump" then
                    if state.infJumpConnection then state.infJumpConnection:Disconnect() end
                    state.infJumpConnection = UserInputService.JumpRequest:Connect(function()
                        local cHum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
                        if cHum then cHum:ChangeState(Enum.HumanoidStateType.Jumping) end
                    end)
                elseif cmdData.name == "uninfinitejump" then
                    if state.infJumpConnection then state.infJumpConnection:Disconnect() state.infJumpConnection = nil end
                elseif cmdData.name == "spin" then
                    stopSpinning()
                    if root then
                        state.isSpinning = true
                        state.spinSpeed = numericArg or 100
                        
                        -- Create a base attachment if one doesn't exist
                        local att = root:FindFirstChild("SpinAttachment") or Instance.new("Attachment")
                        att.Name = "SpinAttachment"
                        att.Parent = root
                        
                        -- 1. Upright Gyro Stabilizer (Keeps you perfectly standing)
                        state.spinGyro = Instance.new("AlignOrientation")
                        state.spinGyro.Name = "SpinStabilizer"
                        state.spinGyro.Mode = Enum.OrientationMode.OneAttachment
                        state.spinGyro.Attachment0 = att
                        -- Allow infinite force to hold you straight up, but don't resist the Y rotation axis
                        state.spinGyro.MaxTorque = math.huge
                        state.spinGyro.Responsiveness = 200
                        state.spinGyro.CFrame = CFrame.new(root.Position, root.Position + Vector3.new(0, 1, 0))
                        state.spinGyro.Parent = root
                        
                        -- 2. Rotational Velocity Generator
                        state.spinVelocity = Instance.new("AngularVelocity")
                        state.spinVelocity.Name = "SpinVelocity"
                        state.spinVelocity.Attachment0 = att
                        state.spinVelocity.MaxTorque = math.huge
                        state.spinVelocity.AngularVelocity = Vector3.new(0, state.spinSpeed, 0)
                        state.spinVelocity.Parent = root
                        
                        -- 3. Invisible Fling Box Setup
                        state.flingPart = Instance.new("Part")
                        state.flingPart.Size = Vector3.new(4.5, 4.5, 4.5)
                        state.flingPart.Transparency = 1
                        state.flingPart.CanCollide = false
                        state.flingPart.Massless = true
                        state.flingPart.Parent = char
                        
                        local motor = Instance.new("Motor6D")
                        motor.Part0 = root
                        motor.Part1 = state.flingPart
                        motor.C0 = CFrame.new(0,0,0)
                        motor.Parent = state.flingPart
                        
                        state.flingPart.Touched:Connect(function(hit)
                            if not state.isSpinning then return end
                            local tChar = hit.Parent
                            local tPlayer = Players:GetPlayerFromCharacter(tChar)
                            if tPlayer and tPlayer ~= LocalPlayer and not state.whitelistedUsers[tPlayer.Name] then
                                local tRoot = tChar:FindFirstChild("HumanoidRootPart")
                                if tRoot then 
                                    tRoot.AssemblyLinearVelocity = Vector3.new(math.random(-5000, 5000), 5000, math.random(-5000, 5000)) 
                                end
                            end
                        end)
                    end
                elseif cmdData.name == "unspin" then
                    stopSpinning()
                elseif cmdData.name == "spinwhitelist" then
                    WhitelistFrame.Visible = true
                    refreshWhitelistRoster()
                end
                break
            end
        end
    end
    if isOpen then
        toggleCommandBar()
    end
end)
